# Copy this file to .env and fill in only the values you use.

# Host user that should own files written by the container.
LOCAL_UID=1000
LOCAL_GID=1000

# Container behavior.
PI_TMUX_SESSION=pi
PI_WORKDIR=/workspace
PI_TELEGRAM_AUTOCONNECT=1
PI_TELEGRAM_AUTOCONNECT_DELAY_SECONDS=5
PI_SCHEDULER_ENABLED=1

# Local model support through host Ollama. The ollama-provider extension registers
# installed host models as an `ollama` provider in Pi.
PI_OLLAMA_ENABLED=1
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gemma4:26b-64k
# Optional comma-separated fallback list used when Ollama discovery is unavailable.
OLLAMA_MODELS=
OLLAMA_API_KEY=ollama
OLLAMA_CONTEXT_WINDOW=128000
OLLAMA_MAX_TOKENS=4096
OLLAMA_DISCOVERY_TIMEOUT_MS=1500

# Runtime data paths on the host. Defaults keep all generated state under ./data.
# For real project checkouts, prefer an external worktrees path such as ../worktrees
# to avoid nesting git repositories inside this public repo.
PI_HOME_DIR=./data/pi-home
PI_EXTENSIONS_DIR=./extensions
PI_SKILLS_DIR=./skills
PI_SCHEDULER_DIR=./scheduler
WORKSPACE_DIR=./data/workspace
WORKTREES_DIR=./data/worktrees
WORKSPACE_AGENTS_DIR=./data/workspace-agents
PI_SSH_DIR=./secrets/ssh
AGENTS_FILE=./AGENTS.example.md

# Optional API keys exposed to the agent process.
FIRECRAWL_ENDPOINT=
FIRECRAWL_API_KEY=
OPENAI_API_KEY=
AITUBO_API_KEY=
RUNWAY_API_KEY=
