# Copy this file to .env and fill in only the values you use.

# Host user that should own files written by the container.
LOCAL_UID=1000
LOCAL_GID=1000

# Container behavior.
PI_TMUX_SESSION=pi
PI_WORKDIR=/workspace
PI_TELEGRAM_AUTOCONNECT=1
PI_SCHEDULER_ENABLED=1

# Runtime data paths on the host. Defaults keep all generated state under ./data.
PI_HOME_DIR=./data/pi-home
PI_EXTENSIONS_DIR=./extensions
PI_SKILLS_DIR=./skills
PI_SCHEDULER_DIR=./scheduler
WORKSPACE_DIR=./data/workspace
WORKTREES_DIR=./data/worktrees
WORKSPACE_AGENTS_DIR=./data/workspace-agents
PI_SSH_DIR=./secrets/ssh
AGENTS_FILE=./AGENTS.example.md

# Optional API keys exposed to the agent process.
FIRECRAWL_ENDPOINT=
FIRECRAWL_API_KEY=
OPENAI_API_KEY=
AITUBO_API_KEY=
RUNWAY_API_KEY=
